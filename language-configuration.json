{
    "comments": {
        "lineComment": "//",
        "blockComment": [
            "/*",
            "*/"
        ]
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "(",
            ")"
        ],
        [
            "[",
            "]"
        ]
    ],
    "autoClosingPairs": [
        {
            "open": "{",
            "close": "}"
        },
        {
            "open": "[",
            "close": "]"
        },
        {
            "open": "(",
            "close": ")"
        },
        {
            "open": "/*",
            "close": "*/"
        }
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(props|data|vertex|fragment|uniforms):",
        "decreaseIndentPattern": "^\\s*(props|data|vertex|fragment|uniforms):"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(props|data|vertex|fragment|uniforms):\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ]
}